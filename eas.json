{
  "cli": {
    "version": ">= 16.3.2",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development"
    },
    "preview_android": {
      "distribution": "internal",
      "environment": "preview",
      "developmentClient": false,
      "android": {
        "buildType": "apk"
      }
    },
    "preview_ios": {
      "distribution": "internal",
      "environment": "preview",
      "ios": {
        "buildConfiguration": "Release",
        "enterpriseProvisioning": "adhoc"
      }
    },
    "production": {
      "autoIncrement": true,
      "environment": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
